{
  "name": "@nahcnuj/makamujo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot index.ts --port=8777",
    "start": "NODE_ENV=production bun index.ts --port=7777",
    "test": "bun test lib/ src/",
    "pretest:e2e": "bunx playwright install --with-deps chromium",
    "test:e2e": "bunx playwright test tests/e2e --timeout=60000",
    "browser": "node --import tsx ./bin/x/browser.ts",
    "generate-ogp": "bun run scripts/generate-ogp.ts",
    "generate-banner": "bun run scripts/generate-banner.ts"
  },
  "dependencies": {
    "@playwright/browser-chromium": "^1.58.2",
    "automated-gameplay-transmitter": "0.5.2",
    "bun": "^1.3.11",
    "bun-plugin-tailwind": "^0.1.2",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0"
  }
}
