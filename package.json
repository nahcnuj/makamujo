{
  "name": "@nahcnuj/makamujo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "react": "hono/jsx/dom",
    "react/jsx-runtime": "hono/jsx/dom/jsx-runtime",
    "react/jsx-dev-runtime": "hono/jsx/dom/jsx-dev-runtime",
    "hono/jsx": "hono/jsx/dom",
    "hono/jsx/jsx-runtime": "hono/jsx/dom/jsx-runtime",
    "hono/jsx/jsx-dev-runtime": "hono/jsx/dom/jsx-dev-runtime"
  },
  "scripts": {
    "dev": "bun --hot index.ts --port=8777",
    "setup": "bun --version && bun ci && bun run typecheck",
    "start": "NODE_ENV=production bun bootstrap.ts --port=7777",
    "typecheck": "tsc --noEmit",
    "test": "bun test lib/ src/ routes/ console/src/ composition/ docs/",
    "test:integration": "MAKAMUJO_ALLOW_FALLBACK_TTS=1 bun test tests/integration/",
    "test:bin": "bash tests/bin/stop.test.sh",
    "pretest:e2e": "playwright install --with-deps chromium && if [ -n \"${CI:-}\" ]; then bash scripts/setup-e2e-tls.sh; fi",
    "test:e2e": "bun run test:e2e:specify -- tests/e2e",
    "pretest:e2e:specify": "playwright install --with-deps chromium >/dev/null && if [ -n \"${CI:-}\" ]; then bash scripts/setup-e2e-tls.sh; fi",
    "test:e2e:specify": "NICONAMA_LIVE_TESTS=1 NICONAMA_START_MAX_RETRIES=0 MAKAMUJO_ALLOW_FALLBACK_TTS=1 CONSOLE_TLS_CERT=var/e2e-tls/fullchain.pem CONSOLE_TLS_KEY=var/e2e-tls/privkey.pem playwright test --timeout=60000",
    "browser": "node --import tsx ./bin/x/browser.ts",
    "generate-ogp": "bun run scripts/generate-ogp.ts",
    "screenshot:console-agent-status": "bun run scripts/capture-console-agent-status.ts",
    "format": "biome format --write .",
    "lint": "biome check --error-on-warnings .",
    "print-comments": "bun run scripts/print-niconama-comment-bodies.ts"
  },
  "dependencies": {
    "@playwright/browser-chromium": "^1.61.1",
    "automated-gameplay-transmitter": "^0.6.4",
    "bun": "^1.3.13",
    "bun-plugin-tailwind": "^0.1.2",
    "hono": "4.12.28",
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tailwindcss": "^4.3.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.2",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
