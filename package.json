{
  "name": "@nahcnuj/makamujo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot index.ts --port=8777",
    "start": "NODE_ENV=production bun index.ts --port=7777",
    "test": "bun test lib/ src/ routes/",
    "test:integration": "bun test tests/integration/",
    "pretest:e2e": "bunx playwright install --with-deps chromium",
    "test:e2e": "bunx playwright test tests/e2e --timeout=60000",
    "browser": "node --import tsx ./bin/x/browser.ts",
    "generate-ogp": "bun run scripts/generate-ogp.ts",
    "generate-banner": "bun run scripts/generate-banner.ts"
  },
  "dependencies": {
    "@playwright/browser-chromium": "^1.57.0",
    "automated-gameplay-transmitter": "^0.5.1",
    "bun": "^1.3.10",
    "bun-plugin-tailwind": "^0.1.2",
    "playwright": "^1.57.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bun": "latest",
    "@types/node": "^24.10.7",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0"
  }
}
