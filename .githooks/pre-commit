#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "Running formatter (package script) for staged files..."

# Find staged files that match common text/code extensions
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx|json|css|scss|html|md|toml)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to format"
  exit 0
fi

# Use the package script when available: prefer `bun run`, then `npm run`, then direct biome binary
if command -v bun >/dev/null 2>&1; then
  RUNNER="bun"
elif command -v npm >/dev/null 2>&1; then
  RUNNER="npm"
elif [ -x "./node_modules/.bin/biome" ]; then
  RUNNER="local"
else
  echo "biome not found. Install it with 'bun add -d @biomejs/biome' or 'npm i -D @biomejs/biome'" >&2
  exit 1
fi

while IFS= read -r file; do
  echo "Formatting $file"
  if [ "$RUNNER" = "bun" ]; then
    bun run format -- "$file"
  elif [ "$RUNNER" = "npm" ]; then
    npm run format -- "$file"
  else
    ./node_modules/.bin/biome format --write "$file"
  fi
  git add -- "$file"
done < <(echo "$STAGED_FILES")

echo "Formatting complete"
exit 0
