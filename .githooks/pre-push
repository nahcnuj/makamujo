#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook for makamujo
# Runs the required repository checks before allowing a push.

cd "$(git rev-parse --show-toplevel)"

echo "Running pre-push checks..."

STDERR_LOG="$(mktemp -t pre-push-stderr.XXXXXX)"

CHECKS_PASSED=0
cleanup() {
  if [ "$CHECKS_PASSED" -eq 1 ]; then
    rm -f "$STDERR_LOG"
  fi
}
trap cleanup EXIT

run_and_log_stderr() {
  echo "==> $*"
  if "$@" 2>>"$STDERR_LOG"; then
    return 0
  else
    echo "Pre-push check failed: $*" >&2
    echo "Read the stderr log file to identify issue(s): $STDERR_LOG" >&2
    exit 1
  fi
}

# Ensure bun is available (use system bun to avoid node_modules/.bin wrappers).
BUN_BIN="$(command -v bun || true)"
if [ -z "$BUN_BIN" ]; then
  echo "bun not available; see stderr log at: $STDERR_LOG" >&2
  exit 1
fi

run_and_log_stderr "$BUN_BIN" run typecheck
# Run tests directly with the system bun binary to avoid nested `bun` invocations
run_and_log_stderr "$BUN_BIN" test lib/ src/ routes/ console/src/
run_and_log_stderr env MAKAMUJO_ALLOW_FALLBACK_TTS=1 "$BUN_BIN" test tests/integration/
# Run e2e pretest and then the specified e2e runner
run_and_log_stderr "$BUN_BIN" run pretest:e2e
run_and_log_stderr "$BUN_BIN" run test:e2e:specify -- tests/e2e

CHECKS_PASSED=1
SUCCESS=1
echo "Pre-push checks passed."
