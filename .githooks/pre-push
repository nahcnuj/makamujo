#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook for makamujo
# Runs the required repository checks before allowing a push.

cd "$(git rev-parse --show-toplevel)"

echo "Running pre-push checks..."

STDERR_LOG="$(mktemp -t pre-push-stderr.XXXXXX)"

CHECKS_PASSED=0
cleanup() {
  if [ "$CHECKS_PASSED" -eq 1 ]; then
    rm -f "$STDERR_LOG"
  fi
}
trap cleanup EXIT

run_and_log_stderr() {
  echo "==> $*"
  if "$@" 2>>"$STDERR_LOG"; then
    return 0
  else
    echo "Pre-push check failed: $*" >&2
    echo "Read the stderr log file to identify issue(s): $STDERR_LOG" >&2
    exit 1
  fi
}

# Ensure bun is available (use system bun to avoid node_modules/.bin wrappers).
BUN_BIN="$(command -v bun || true)"
if [ -z "$BUN_BIN" ]; then
  echo "bun not available; see stderr log at: $STDERR_LOG" >&2
  exit 1
fi

run_and_log_stderr "$BUN_BIN" run typecheck
run_and_log_stderr "$BUN_BIN" run test
run_and_log_stderr "$BUN_BIN" run test:integration
run_and_log_stderr "$BUN_BIN" run test:e2e

CHECKS_PASSED=1
SUCCESS=1
echo "Pre-push checks passed."
