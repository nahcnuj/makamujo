{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "includes": ["**", "!docs/index.html", "!var"]
  },
  "overrides": [
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "index.ts",
        "lib/Browser/chromium.ts",
        "lib/Agent/index.ts",
        "lib/Agent/games/org.dashnet.orteil/cookieclicker/solver.ts",
        "lib/console-proxy.ts",
        "lib/niconamaCommentClient.ts",
        "lib/niconamaCommentClient.helpers.ts",
        "lib/niconamaCommentClient.playwright.ts",
        "lib/streamState.ts",
        "routes/index.ts",
        "routes/console/index.ts",
        "scripts/*.ts",
        "src/contexts/AgentContext.tsx",
        "tests/helpers/mock-upstream-server.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "performance": {
            "noAccumulatingSpread": "off"
          },
          "correctness": {
            "noUnusedPrivateClassMembers": "off",
            "noUnusedFunctionParameters": "off"
          }
        }
      }
    }
  ]
}
