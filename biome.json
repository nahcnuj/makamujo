{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "off",
        "noImplicitAnyLet": "off",
        "useIterableCallbackReturn": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "complexity": {
        "noBannedTypes": "off"
      },
      "security": {
        "noGlobalEval": "off"
      },
      "a11y": {
        "useAltText": "off"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!docs/index.html",
      "!docs/banner.svg",
      "!var",
      "!playwright/.auth",
      "!test-results",
      "!bun.lock",
      "!obs-studio"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx"],
      "formatter": {
        "enabled": true
      },
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["scripts/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    }
  ]
}
