#!/usr/bin/env sh

set -eu

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PROJECT_ROOT=$(cd "${SCRIPT_DIR}/../.." && pwd)

PID_DIR="${PROJECT_ROOT}/var/pid"
mkdir -p "${PID_DIR}"

cd "${PROJECT_ROOT}"

nohup bun start >"${PROJECT_ROOT}/var/screen.log" 2>&1 &
echo $! > "${PID_DIR}/screen"

nohup bun ./bin/x/browser.ts >"${PROJECT_ROOT}/var/browser.log" 2>&1 &
echo $! > "${PID_DIR}/browser"

nohup bun ./bin/x/obs >"${PROJECT_ROOT}/var/obs.log" 2>&1 &
echo $! > "${PID_DIR}/obs"
