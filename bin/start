#!/usr/bin/env sh

set -eu

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PROJECT_ROOT=$(cd "${SCRIPT_DIR}/.." && pwd)

PID_DIR="${PROJECT_ROOT}/var/pid"
mkdir -p "${PID_DIR}"

cd "${PROJECT_ROOT}"

BUN_PATH=$(command -v bun 2>/dev/null || true)
if [ -z "${BUN_PATH}" ]; then
  BUN_PATH="bun"
fi

# Check if running under systemd
UNDER_SYSTEMD=0
if [ -n "${SYSTEMD_UNIT:-}" ] || systemctl-is-system-running >/dev/null 2>&1; then
  UNDER_SYSTEMD=1
fi

if [ "$UNDER_SYSTEMD" -eq 1 ]; then
  # Under systemd: start child services (screen → browser → obs via After= directives)
  systemctl start makamujo-screen.service
  systemctl start makamujo-browser.service
  systemctl start makamujo-obs.service
else
  # Fallback: systemd not available, use nohup
  nohup /bin/sh -lc "cd '${PROJECT_ROOT}' && NODE_ENV=production '${BUN_PATH}' start" >"${PROJECT_ROOT}/var/screen.log" 2>&1 &
  echo $! > "${PID_DIR}/screen"
  
  nohup /bin/sh -lc "cd '${PROJECT_ROOT}' && NODE_ENV=production '${BUN_PATH}' '${PROJECT_ROOT}/bin/x/browser.ts'" >"${PROJECT_ROOT}/var/browser.log" 2>&1 &
  echo $! > "${PID_DIR}/browser"
  
  nohup /bin/sh -lc "cd '${PROJECT_ROOT}' && '${PROJECT_ROOT}/bin/x/obs'" >"${PROJECT_ROOT}/var/obs.log" 2>&1 &
  echo $! > "${PID_DIR}/obs"
fi

exit 0
