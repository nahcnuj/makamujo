#!/usr/bin/env sh

set -eu

SCRIPT_PATH=$(dirname "$0")
OBS_STUDIO="${SCRIPT_PATH}/../obs-studio"

_DISPLAY_EXPLICIT=''
_XAUTHORITY_EXPLICIT=''

while [ $# -gt 0 ]; do
  case "$1" in
    --display)
      export DISPLAY="$2"
      _DISPLAY_EXPLICIT=1
      shift 2
      ;;
    --xauthority)
      export XAUTHORITY="$2"
      _XAUTHORITY_EXPLICIT=1
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

# When --display is not given, auto-detect the display from the first X11
# socket found in /tmp/.X11-unix/ (e.g. xrdp uses :10, not :0).
if [ -z "$_DISPLAY_EXPLICIT" ]; then
  for _sock in /tmp/.X11-unix/X*; do
    if [ -S "$_sock" ]; then
      _num="${_sock##*/X}"
      export DISPLAY=":${_num}"
      break
    fi
  done
fi

# When --display is given (or auto-detected) without --xauthority, try to
# auto-detect the Xauthority file from the owner of the X11 socket so that
# connections from a different login session (e.g. serial console as root)
# can authenticate.
if [ -n "${DISPLAY:-}" ] && [ -z "$_XAUTHORITY_EXPLICIT" ]; then
  _display_num="${DISPLAY#:}"
  _display_num="${_display_num%%.*}"
  _socket="/tmp/.X11-unix/X${_display_num}"
  if [ -S "$_socket" ]; then
    _owner=$(stat -c '%U' "$_socket" 2>/dev/null || true)
    if [ -n "$_owner" ]; then
      _home=$(getent passwd "$_owner" 2>/dev/null | cut -d: -f6 || true)
      if [ -n "$_home" ] && [ -f "${_home}/.Xauthority" ]; then
        export XAUTHORITY="${_home}/.Xauthority"
      fi
    fi
  fi
fi

"${OBS_STUDIO}" \
    --startstreaming \
    --disable-shutdown-check \
    --disable-missing-files-check \
    --disable-updater \
    --unfiltered_log \
    --verbose